{
  "name": "agendapro",
  "version": "1.0.0",
  "description": "AgendaPro - Sistema de agendamento para profissionais",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "dev": "npm run build && npx serve -l 3000 dist",
    "test": "node tests/run-tests.js",
    "test:db:local": "node tests/run-db-smoke.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "dev": "node server.js",
    "serve": "node server.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "dotenv": "^16.3.1"
  }
}
