# AgendaPro - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais

# ============================================
# SUPABASE (obrigatório)
# ============================================
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON=eyJh... (chave pública anônima)

# ============================================
# ADMIN PAINEL (obrigatório para acessar /admin)
# ============================================
# Senha simples para acessar o painel admin
# Use uma senha forte em produção (min 16 caracteres)
ADMIN_PASSWORD=sua_senha_admin_aqui_muito_forte_e_longa

# ============================================
# FIREBASE (obrigatório)
# ============================================
APP_URL=https://e-agendapro.web.app

# ============================================
# SENTRY - Monitoramento de Erros (recomendado)
# ============================================
# Crie conta em https://sentry.io e obtenha o DSN do projeto
SENTRY_DSN=https://xxx@sentry.io/SEU_PROJETO_ID
SENTRY_ENVIRONMENT=production  # ou 'development', 'staging'

# ============================================
# ASAAS - Pagamentos (obrigatório para produção)
# ============================================
ASAAS_API_KEY=$aas_xxx
ASAAS_WEBHOOK_TOKEN=token_seguro_aleatorio

# ============================================
# EVOLUTION API - WhatsApp (obrigatório para Pro)
# ============================================
# Instale em VPS (Oracle Free Tier recomendado)
# Veja SETUP-EVOLUTION-API-ORACLE.md para guia completo
EVOLUTION_API_URL=https://SEU_IP_OU_DOMINIO:8080
EVOLUTION_API_KEY=SEU_TOKEN_AQUI
EVOLUTION_INSTANCE_NAME=agendapro-prod

# ============================================
# SENDGRID - Email (obrigatório para Free)
# ============================================
# Conta gratuita: 100 emails/dia
# Crie conta em https://sendgrid.com
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@agendapro.com.br
SENDGRID_FROM_NAME=AgendaPro

# ============================================
# GOOGLE CALENDAR (opcional)
# ============================================
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ============================================
# PLAUSIBLE - Analytics (opcional)
# ============================================
PLAUSIBLE_DOMAIN=agendapro.com.br
